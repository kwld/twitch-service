APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080
APP_LOG_LEVEL=info
APP_EVENTSUB_LOG_PATH=./logs/eventsub.log
APP_ALLOWED_IPS=
APP_TRUST_X_FORWARDED_FOR=false
APP_WEBHOOK_TARGET_ALLOWLIST=
APP_BLOCK_PRIVATE_WEBHOOK_TARGETS=true
LOKI_HOST=
LOKI_PORT=
ALLOY_PORT=12345

POSTGRES_DB=twitch_eventsub
POSTGRES_USER=twitch
POSTGRES_PASSWORD=twitch
DATABASE_URL=postgresql+asyncpg://twitch:twitch@localhost:5432/twitch_eventsub
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

TWITCH_CLIENT_ID=replace_me
TWITCH_CLIENT_SECRET=replace_me
TWITCH_REDIRECT_URI=http://localhost:8080/oauth/callback
TWITCH_DEFAULT_SCOPES=channel:bot user:bot user:read:chat user:write:chat clips:edit chat:read chat:edit channel:moderate moderator:read:followers moderator:read:blocked_terms moderator:read:chat_settings moderator:read:unban_requests moderator:read:banned_users moderator:read:chat_messages moderator:read:moderators moderator:read:vips moderator:read:warnings moderator:manage:banned_users moderator:manage:chat_messages moderator:manage:blocked_terms moderator:manage:automod moderator:manage:warnings moderator:manage:chat_settings
TWITCH_EVENTSUB_WS_URL=wss://eventsub.wss.twitch.tv/ws
TWITCH_EVENTSUB_WEBHOOK_CALLBACK_URL=https://your-public-domain.com/webhooks/twitch/eventsub
TWITCH_EVENTSUB_WEBHOOK_SECRET=replace_me_32_plus_chars
TWITCH_EVENTSUB_WEBHOOK_EVENT_TYPES=stream.online,stream.offline

SERVICE_SIGNING_SECRET=replace_me_very_long_secret
ADMIN_API_KEY=replace_me_admin_key

NGROK_DOMAIN=
NGROK_AUTHTOKEN=
